<!DOCTYPE html>
<html lang="en">
@{
    Layout = null;
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital_Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hospital_Management.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="~/css/admindashboard.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-white" href="#">🏥 Admin Dashboard</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    <!-- Doctor -->
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">👨‍⚕️ Doctor</a>
                    </li>

                    <!-- Department -->
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Department/DepartmentList">🏬 Department</a>
                    </li>

                    <!-- Patient -->
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">🧑‍🤝‍🧑 Patient</a>
                    </li>

                    <!-- Appointment -->
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">📅 Appointment</a>
                    </li>

                    <!-- Logout -->
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Logout">🚪 Logout</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/AdminDashboard">⬅️Back to Dasboard</a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>


    <main role="main" class="pb-3">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
</body>
</html>
