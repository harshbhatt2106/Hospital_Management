@* AdminProfile.cshtml *@
<div class="admin-profile-container">
    <div class="profile-grid">
        <!-- Personal Information Section -->
        <div class="profile-card profile-personal">
            <div class="card-header">
                <div class="header-icon">
                    <i class="fas fa-id-card"></i>
                </div>
                <h3>Personal Information</h3>
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Username</span>
                        <span class="info-value">admin</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email</span>
                        <span class="info-value">admin123@gmail.com</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Mobile</span>
                        <span class="info-value">9586977634</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Last Modified</span>
                        <span class="info-value">2025-06-27 16:35:17</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Password Management Section -->
        <div class="profile-card profile-security">
            <div class="card-header">
                <div class="header-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3>Security Center</h3>
            </div>
            <div class="card-body">
                <div class="security-grid">
                    <div class="password-reset">
                        <h4>Reset Password</h4>
                        <form class="password-form">
                            <div class="form-group">
                                <label>New Password</label>
                                <div class="password-input">
                                    <input type="password" placeholder="Enter new password">
                                    <i class="fas fa-eye toggle-password"></i>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Confirm Password</label>
                                <div class="password-input">
                                    <input type="password" placeholder="Confirm new password">
                                    <i class="fas fa-eye toggle-password"></i>
                                </div>
                            </div>
                            <button type="submit" class="btn-update">
                                <i class="fas fa-sync-alt"></i> Update Password
                            </button>
                        </form>
                    </div>
                    <div class="password-recovery">
                        <h4>Account Recovery</h4>
                        <p>Secure your account with multi-factor authentication</p>
                        <button class="btn-recovery">
                            <i class="fas fa-key"></i> Enable MFA
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Dashboard -->
        <div class="profile-card profile-stats">
            <div class="card-header">
                <div class="header-icon">
                    <i class="fas fa-chart-network"></i>
                </div>
                <h3>System Overview</h3>
            </div>
            <div class="card-body">
                <div class="stats-grid">
                    <div class="stat-card doctor-stat">
                        <div class="stat-icon">
                            <i class="fas fa-user-md"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-number">142</span>
                            <span class="stat-label">Total Doctors</span>
                        </div>
                    </div>
                    <div class="stat-card dept-stat">
                        <div class="stat-icon">
                            <i class="fas fa-building"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-number">56</span>
                            <span class="stat-label">Departments</span>
                        </div>
                    </div>
                    <div class="stat-card admin-stat">
                        <div class="stat-icon">
                            <i class="fas fa-users-cog"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-number">3</span>
                            <span class="stat-label">Administrators</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Admin Status Table -->
        <div class="profile-card profile-admin-table">
            <div class="card-header">
                <div class="header-icon">
                    <i class="fas fa-user-shield"></i>
                </div>
                <h3>Administrator Status</h3>
            </div>
            <div class="card-body">
                <div class="admin-table">
                    <div class="table-responsive">
                        <table class="admin-status-table">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="user-avatar">
                                            <span>H</span>
                                        </div>
                                        <span>Harsh</span>
                                    </td>
                                    <td>harshbhatt932@gmail.com</td>
                                    <td>
                                        <span class="status-badge active">Active</span>
                                    </td>
