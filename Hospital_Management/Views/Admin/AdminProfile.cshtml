                                </tr>
                                <tr>
                                    <td>
                                        <div class="user-avatar">
                                            <span>B</span>
                                        </div>
                                        <span>bhatt</span>
                                    </td>
                                    <td>bhatt@gmail.com</td>
                                    <td>
                                        <span class="status-badge inactive">Inactive</span>
                                    </td>
                                    <td>2025-06-27 16:36:44</td>
                                </tr>
