@model User

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 p-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Left Side: Profile -->
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <h2 class="text-2xl font-bold mb-4 text-gray-800">👤 Admin Profile</h2>
            <div class="flex items-center space-x-4 mb-6">
                <img src="https://via.placeholder.com/80" alt="Avatar" class="rounded-full w-20 h-20 border-2 border-indigo-500" />
                <div>
                    <h3 class="text-xl font-semibold">@Model.UserName</h3>
                    <p class="text-gray-500">Administrator</p>
                </div>
            </div>
            <div class="space-y-2 text-gray-700">
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.MobileNo</p>
                <p><strong>Joined:</strong> @Model.Created</p>
            </div>
        </div>

        <!-- Right Side: System Overview -->
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <h2 class="text-2xl font-bold mb-4 text-gray-800">🖥️ System Overview</h2>
            <ul class="space-y-2 text-gray-700">
                <li>✔️ Total Users: @ViewBag.adminCount</li>
                <li>✔️ Total Doctors: @ViewBag.doctorCount</li>
                <li>✔️ Total Departments: @ViewBag.departmentCount</li>
                <li>✔️ Active Sessions: 8</li>
            </ul>
        </div>

        <!-- Reset Password -->
        <div class="bg-white rounded-2xl shadow-lg p-6 col-span-1">
            <h2 class="text-2xl font-bold mb-4 text-gray-800">🔐 Reset Password</h2>
            <form class="space-y-4">
                <input type="password" placeholder="Old Password" class="w-full border rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input type="password" placeholder="New Password" class="w-full border rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input type="password" placeholder="Confirm New Password" class="w-full border rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <button class="bg-indigo-600 text-white px-6 py-2 rounded-xl hover:bg-indigo-700 transition">Update Password</button>
            </form>
        </div>

        <!-- Forgot Password -->
        <div class="bg-white rounded-2xl shadow-lg p-6 col-span-1">
            <h2 class="text-2xl font-bold mb-4 text-gray-800">❓ Forgot Password</h2>
            <form class="space-y-4">
                <input type="email" placeholder="Enter your email" class="w-full border rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500" />
                <button class="bg-red-600 text-white px-6 py-2 rounded-xl hover:bg-red-700 transition">Send Recovery Link</button>
            </form>
        </div>
    </div>

</body>
</html>
